---
import type { Locale } from '../../utils/i18n';
import { useTranslations } from '../../utils/i18n';
import { Image } from 'astro:assets';

interface Props {
  locale: Locale;
  name: string;
  position: string;
  bio: string;
  image?: string;
  email: string;
  linkedin?: string;
  awards?: string[];
  compact?: boolean;
}

const { locale, name, position, bio, image, email, linkedin, awards = [], compact = false } = Astro.props;
const t = useTranslations(locale);

// Generate initials for placeholder
const initials = name.split(' ').map((n) => n[0]).join('').toUpperCase().slice(0, 2);
---

<article class="bg-white border border-bg-light rounded-sm overflow-hidden">
  <!-- Photo area -->
  <div class="aspect-[4/3] bg-bg-light flex items-center justify-center overflow-hidden">
    {image ? (
      <img
        src={image}
        alt={name}
        class="w-full h-full object-cover object-top"
        loading="lazy"
        width="400"
        height="300"
      />
    ) : (
      <div
        class="w-full h-full bg-bg-dark flex items-center justify-center"
        aria-hidden="true"
      >
        <span class="font-heading font-bold text-4xl text-white/40">{initials}</span>
      </div>
    )}
  </div>

  <!-- Content -->
  <div class="p-6">
    <h3 class="font-heading font-bold text-xl text-text mb-1">{name}</h3>
    <p class="font-sans text-sm text-accent font-semibold mb-3 uppercase tracking-wide">{position}</p>

    {!compact && (
      <p class="font-sans text-sm text-text/70 leading-relaxed mb-4 line-clamp-4">{bio}</p>
    )}

    {awards.length > 0 && (
      <ul class="flex flex-wrap gap-2 mb-4 list-none m-0 p-0" aria-label={t.team.awards}>
        {awards.map((award) => (
          <li>
            <span class="inline-block text-xs font-sans bg-bg-light text-text/60 px-2 py-1 rounded-sm border border-bg-light">
              {award}
            </span>
          </li>
        ))}
      </ul>
    )}

    <!-- Contact links -->
    <div class="flex items-center gap-4 pt-3 border-t border-bg-light">
      <a
        href={`mailto:${email}`}
        class="text-sm font-heading font-semibold text-text hover:text-accent transition-colors flex items-center gap-1"
        aria-label={`${t.team.email}: ${name}`}
      >
        <svg aria-hidden="true" class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
        </svg>
        {t.team.email}
      </a>

      {linkedin && (
        <a
          href={linkedin}
          target="_blank"
          rel="noopener noreferrer"
          class="text-sm font-heading font-semibold text-text hover:text-accent transition-colors flex items-center gap-1"
          aria-label={`${t.team.linkedin}: ${name} ${t.aria.externalLink}`}
        >
          <svg aria-hidden="true" class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452z"/>
          </svg>
          LinkedIn
        </a>
      )}
    </div>
  </div>
</article>
