---
import type { Locale } from '../../utils/i18n';
import { useTranslations, getLocalizedUrl } from '../../utils/i18n';
import LanguageSwitcher from './LanguageSwitcher.astro';

interface Props {
  locale: Locale;
  currentUrl: URL;
}

const { locale, currentUrl } = Astro.props;
const t = useTranslations(locale);
---

<!-- Hamburger Button (visible on mobile only) -->
<button
  id="mobile-menu-toggle"
  type="button"
  class="lg:hidden flex items-center justify-center w-10 h-10 text-text hover:text-accent
         transition-colors focus-visible:outline-2 focus-visible:outline-accent rounded-sm"
  aria-expanded="false"
  aria-controls="mobile-menu"
  aria-label={t.nav.menuOpen}
>
  <!-- Hamburger icon -->
  <svg id="icon-open" aria-hidden="true" class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
  </svg>
  <!-- Close icon -->
  <svg id="icon-close" aria-hidden="true" class="w-6 h-6 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
  </svg>
</button>

<!-- Mobile Menu Overlay -->
<div
  id="mobile-menu"
  class="hidden lg:hidden fixed inset-0 top-[68px] bg-white z-40 overflow-y-auto"
  role="dialog"
  aria-modal="true"
  aria-label={t.aria.mainNav}
>
  <nav class="container py-6">
    <ul class="list-none m-0 p-0 space-y-1" role="list">
      <!-- Expertise with accordion -->
      <li>
        <button
          id="mobile-expertise-toggle"
          type="button"
          class="flex w-full items-center justify-between px-4 py-3 font-heading font-semibold text-lg
                 text-text hover:text-accent hover:bg-bg-light transition-colors rounded-sm"
          aria-expanded="false"
          aria-controls="mobile-expertise-list"
        >
          {t.nav.expertise}
          <svg
            aria-hidden="true"
            id="expertise-chevron"
            class="w-5 h-5 transition-transform"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
          </svg>
        </button>

        <ul id="mobile-expertise-list" class="hidden pl-4 space-y-1 mt-1 list-none" role="list">
          {t.nav.expertiseItems.map((item) => (
            <li>
              <a
                href={getLocalizedUrl(locale, `/expertise/${item.slug}/`)}
                class="block px-4 py-2 text-base font-sans text-text hover:text-accent hover:bg-bg-light
                       transition-colors rounded-sm focus-visible:outline-2 focus-visible:outline-accent"
              >
                {item.label}
              </a>
            </li>
          ))}
          <li>
            <a
              href={getLocalizedUrl(locale, '/expertise/')}
              class="block px-4 py-2 text-base font-heading font-semibold text-accent hover:bg-bg-light
                     transition-colors rounded-sm"
            >
              {t.expertise.allAreas} →
            </a>
          </li>
        </ul>
      </li>

      {[
        { label: t.nav.team, href: getLocalizedUrl(locale, '/team/') },
        { label: t.nav.news, href: getLocalizedUrl(locale, '/news/') },
        { label: t.nav.jobs, href: getLocalizedUrl(locale, '/jobs/') },
        { label: t.nav.contact, href: getLocalizedUrl(locale, locale === 'de' ? '/kontakt/' : '/contact/') },
      ].map((link) => (
        <li>
          <a
            href={link.href}
            class="block px-4 py-3 font-heading font-semibold text-lg text-text hover:text-accent
                   hover:bg-bg-light transition-colors rounded-sm focus-visible:outline-2 focus-visible:outline-accent"
            aria-current={currentUrl.pathname.startsWith(link.href) ? 'page' : undefined}
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>

    <!-- Language Switcher in mobile -->
    <div class="mt-6 pt-6 border-t border-bg-light">
      <LanguageSwitcher locale={locale} currentUrl={currentUrl} class="w-full justify-center py-3" />
    </div>

    <!-- Contact info shortcut -->
    <div class="mt-6 pt-6 border-t border-bg-light space-y-3">
      <a
        href="tel:+41435557000"
        class="flex items-center gap-3 text-text hover:text-accent transition-colors font-sans"
      >
        <svg aria-hidden="true" class="w-5 h-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
        </svg>
        +41 43 555 70 00
      </a>
      <a
        href="mailto:info@core-attorneys.com"
        class="flex items-center gap-3 text-text hover:text-accent transition-colors font-sans"
      >
        <svg aria-hidden="true" class="w-5 h-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
        </svg>
        info@core-attorneys.com
      </a>
    </div>
  </nav>
</div>

<script>
  const toggle = document.getElementById('mobile-menu-toggle');
  const menu = document.getElementById('mobile-menu');
  const iconOpen = document.getElementById('icon-open');
  const iconClose = document.getElementById('icon-close');
  const expertiseToggle = document.getElementById('mobile-expertise-toggle');
  const expertiseList = document.getElementById('mobile-expertise-list');
  const expertiseChevron = document.getElementById('expertise-chevron');

  toggle?.addEventListener('click', () => {
    const isOpen = menu?.classList.toggle('hidden');
    // isOpen = true means we just added 'hidden' (closed)
    const expanded = !menu?.classList.contains('hidden');
    toggle.setAttribute('aria-expanded', String(expanded));
    iconOpen?.classList.toggle('hidden', expanded);
    iconClose?.classList.toggle('hidden', !expanded);
    document.body.style.overflow = expanded ? 'hidden' : '';
    // Update aria-label
    const t = expanded
      ? toggle.getAttribute('data-close-label') ?? 'Close menu'
      : toggle.getAttribute('data-open-label') ?? 'Open menu';
  });

  expertiseToggle?.addEventListener('click', () => {
    const isHidden = expertiseList?.classList.toggle('hidden');
    expertiseToggle.setAttribute('aria-expanded', String(!isHidden));
    expertiseChevron?.classList.toggle('rotate-180', !isHidden);
  });

  // Close on escape
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && !menu?.classList.contains('hidden')) {
      menu?.classList.add('hidden');
      toggle?.setAttribute('aria-expanded', 'false');
      iconOpen?.classList.remove('hidden');
      iconClose?.classList.add('hidden');
      document.body.style.overflow = '';
      toggle?.focus();
    }
  });
</script>
