---
import type { Locale } from '../../utils/i18n';
import { useTranslations, getAlternateLocaleUrl } from '../../utils/i18n';

interface Props {
  locale: Locale;
  currentUrl: URL;
  class?: string;
}

const { locale, currentUrl, class: className } = Astro.props;
const t = useTranslations(locale);
const alternateLocale: Locale = locale === 'de' ? 'en' : 'de';
const alternateUrl = getAlternateLocaleUrl(currentUrl, alternateLocale);
---

<a
  href={alternateUrl}
  lang={alternateLocale}
  aria-label={t.nav.langSwitch}
  class:list={[
    'inline-flex items-center font-heading font-semibold text-sm tracking-wide',
    'text-text hover:text-accent transition-colors duration-200',
    'border border-text/30 hover:border-accent px-3 py-1 rounded-sm',
    className,
  ]}
>
  {t.nav.langSwitchShort}
</a>
