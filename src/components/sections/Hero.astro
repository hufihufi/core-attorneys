---
import type { Locale } from '../../utils/i18n';
import { useTranslations, getLocalizedUrl } from '../../utils/i18n';

interface Props {
  locale: Locale;
  tagline?: string;
  subtext?: string;
}

const { locale, tagline, subtext } = Astro.props;
const t = useTranslations(locale);

const heroTagline = tagline ?? t.hero.tagline;
---

<section
  class="relative bg-white overflow-hidden"
  aria-labelledby="hero-heading"
>
  <!-- Background accent bar -->
  <div class="absolute left-0 top-0 bottom-0 w-1 bg-accent" aria-hidden="true"></div>

  <div class="container py-20 lg:py-28 pl-8">
    <div class="max-w-3xl">
      <h1
        id="hero-heading"
        class="font-heading font-bold text-text leading-tight mb-6"
        style="font-size: clamp(32px, 5vw, 52px);"
      >
        {heroTagline}
      </h1>

      {subtext && (
        <p class="font-sans text-lg text-text/70 mb-8 max-w-2xl leading-relaxed">
          {subtext}
        </p>
      )}

      <div class="flex flex-wrap gap-4">
        <a
          href={getLocalizedUrl(locale, '/expertise/')}
          class="btn-accent"
        >
          {t.hero.cta}
        </a>
        <a
          href={getLocalizedUrl(locale, '/team/')}
          class="btn-outline"
        >
          {t.hero.ctaSecondary}
        </a>
      </div>

      <!-- Trust signals -->
      <div class="mt-12 flex flex-wrap items-center gap-6 text-sm text-text/50 font-sans">
        <div class="flex items-center gap-2">
          <svg aria-hidden="true" class="w-5 h-5 text-accent" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
          </svg>
          <span>Who's Who Legal</span>
        </div>
        <div class="flex items-center gap-2">
          <svg aria-hidden="true" class="w-5 h-5 text-accent" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
          </svg>
          <span>Chambers &amp; Partners</span>
        </div>
        <div class="flex items-center gap-2">
          <svg aria-hidden="true" class="w-5 h-5 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
          </svg>
          <span>{locale === 'de' ? 'Zürich, Schweiz' : 'Zurich, Switzerland'}</span>
        </div>
      </div>
    </div>
  </div>
</section>
