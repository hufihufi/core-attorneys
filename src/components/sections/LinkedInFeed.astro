---
import type { Locale } from '../../utils/i18n';
import { useTranslations } from '../../utils/i18n';

interface Props {
  locale: Locale;
  /** Walls.io widget ID from the embed code */
  widgetId?: string;
}

const { locale, widgetId } = Astro.props;
const t = useTranslations(locale);

// If no widget ID is configured, show a placeholder
const hasWidget = Boolean(widgetId);
---

<section class="py-16 lg:py-20 bg-white" aria-label={t.aria.linkedinFeed}>
  <div class="container">
    <header class="mb-8">
      <h2
        class="font-heading font-bold text-text mb-3"
        style="font-size: clamp(28px, 4vw, 36px);"
      >
        {locale === 'de' ? 'CORE Attorneys auf LinkedIn' : 'CORE Attorneys on LinkedIn'}
      </h2>
      <p class="font-sans text-text/60">
        {locale === 'de'
          ? 'Aktuelle Beiträge und Einblicke aus unserer Kanzlei.'
          : 'Latest posts and insights from our firm.'}
      </p>
    </header>

    {hasWidget ? (
      <>
        <!-- Privacy notice above the widget -->
        <div
          class="mb-4 p-4 bg-bg-light border border-bg-light rounded-sm text-sm font-sans text-text/60"
          role="note"
        >
          <strong class="text-text">{locale === 'de' ? 'Datenschutzhinweis:' : 'Privacy notice:'}</strong>
          {' '}
          {locale === 'de'
            ? 'Dieser Feed wird über Walls.io bereitgestellt. Beim Laden werden Daten an Walls.io und LinkedIn übertragen. Weitere Informationen finden Sie in unserer '
            : 'This feed is provided by Walls.io. Loading it transfers data to Walls.io and LinkedIn. For more information, see our '}
          <a
            href={`/${locale}/${locale === 'de' ? 'datenschutz' : 'privacy'}/`}
            class="text-accent underline hover:no-underline"
          >
            {locale === 'de' ? 'Datenschutzerklärung' : 'Privacy Policy'}
          </a>.
        </div>

        <!-- Walls.io embed (lazy loaded) -->
        <div
          id="linkedin-feed-container"
          class="min-h-[400px]"
        >
          <!-- The iframe is injected by the script below to enable lazy loading -->
          <noscript>
            <p class="font-sans text-text/60">
              {locale === 'de'
                ? 'Bitte aktivieren Sie JavaScript, um den LinkedIn-Feed zu laden.'
                : 'Please enable JavaScript to load the LinkedIn feed.'}
            </p>
          </noscript>
        </div>

        <script define:vars={{ widgetId }}>
          // Lazy-load the Walls.io widget only when visible
          const container = document.getElementById('linkedin-feed-container');
          if (container && widgetId) {
            const observer = new IntersectionObserver(
              (entries) => {
                entries.forEach((entry) => {
                  if (entry.isIntersecting) {
                    const iframe = document.createElement('iframe');
                    iframe.src = `https://walls.io/${widgetId}?nobacklink=1`;
                    iframe.style.cssText = 'width:100%;min-height:500px;border:none;';
                    iframe.title = 'LinkedIn Feed von CORE Attorneys via Walls.io';
                    iframe.loading = 'lazy';
                    iframe.allow = '';
                    container.appendChild(iframe);
                    observer.disconnect();
                  }
                });
              },
              { threshold: 0.1 }
            );
            observer.observe(container);
          }
        </script>
      </>
    ) : (
      <!-- Fallback: LinkedIn link when no widget is configured -->
      <div class="flex flex-col sm:flex-row items-start sm:items-center gap-6 p-8 bg-bg-light rounded-sm border border-bg-light">
        <svg aria-hidden="true" class="w-12 h-12 text-[#0A66C2] flex-shrink-0" fill="currentColor" viewBox="0 0 24 24">
          <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
        </svg>
        <div>
          <p class="font-sans text-text/80 mb-4">
            {locale === 'de'
              ? 'Folgen Sie uns auf LinkedIn für aktuelle Einblicke und Neuigkeiten aus der Kanzlei.'
              : 'Follow us on LinkedIn for current insights and news from the firm.'}
          </p>
          <a
            href="https://www.linkedin.com/company/core-attorneys"
            target="_blank"
            rel="noopener noreferrer"
            class="btn-accent"
            aria-label={`${t.footer.linkedin} ${t.aria.externalLink}`}
          >
            {locale === 'de' ? 'CORE Attorneys auf LinkedIn folgen' : 'Follow CORE Attorneys on LinkedIn'}
          </a>
        </div>
      </div>
    )}
  </div>
</section>
