---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../components/layout/BaseLayout.astro';
import JsonLd from '../../../components/seo/JsonLd.astro';

export async function getStaticPaths() {
  const expertise = await getCollection('expertise_de');
  return expertise.map((item) => ({
    params: { slug: item.slug.split('/').pop() ?? item.slug },
    props: { item },
  }));
}

const { item } = Astro.props;
const { Content } = await item.render();

const locale = 'de';
const slug = item.slug.split('/').pop() ?? item.slug;
const canonicalUrl = `https://www.core-attorneys.com/de/expertise/${slug}/`;
// Map DE slug to EN slug (best effort – should be maintained in content)
const alternateUrl = `https://www.core-attorneys.com/en/expertise/${slug}/`;

const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: item.data.title,
  description: item.data.description,
  provider: { '@id': 'https://www.core-attorneys.com/#organization' },
  serviceType: item.data.title,
  url: canonicalUrl,
};

// FAQ schema: extract headings from summary as FAQ if it contains Q&A patterns
// (can be extended when real content is available)
---

<BaseLayout
  title={`${item.data.title} | CORE Attorneys`}
  description={item.data.description}
  locale={locale}
  canonicalUrl={canonicalUrl}
  alternateUrl={alternateUrl}
  schemas={[serviceSchema]}
>
  <!-- Page header -->
  <div class="py-12 bg-bg-light border-b border-bg-light">
    <div class="container">
      <nav aria-label="Brotkrümelpfad" class="mb-4">
        <ol class="flex items-center gap-2 text-sm font-sans text-text/50 list-none m-0 p-0">
          <li><a href="/de/" class="hover:text-accent transition-colors">Startseite</a></li>
          <li aria-hidden="true" class="text-text/30">/</li>
          <li><a href="/de/expertise/" class="hover:text-accent transition-colors">Expertise</a></li>
          <li aria-hidden="true" class="text-text/30">/</li>
          <li class="text-text" aria-current="page">{item.data.title}</li>
        </ol>
      </nav>
      <div class="w-12 h-1 bg-accent mb-4" aria-hidden="true"></div>
      <h1 class="font-heading font-bold text-text" style="font-size: clamp(32px, 5vw, 48px);">
        {item.data.title}
      </h1>
      <p class="font-sans text-lg text-text/60 mt-3 max-w-3xl">
        {item.data.summary}
      </p>
    </div>
  </div>

  <!-- Content -->
  <div class="py-16 lg:py-20">
    <div class="container">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">
        <!-- Main content -->
        <div class="lg:col-span-2">
          <div class="prose prose-lg max-w-none
            prose-headings:font-heading prose-headings:text-text
            prose-a:text-accent prose-a:no-underline hover:prose-a:underline
            prose-strong:text-text">
            <Content />
          </div>
        </div>

        <!-- Sidebar -->
        <aside class="space-y-6">
          <!-- Contact CTA -->
          <div class="bg-bg-light p-6 border-l-4 border-accent">
            <h2 class="font-heading font-semibold text-lg text-text mb-3">
              Beratung anfragen
            </h2>
            <p class="font-sans text-sm text-text/70 mb-4">
              Haben Sie Fragen zu diesem Bereich? Kontaktieren Sie uns direkt.
            </p>
            <a href="/de/kontakt/" class="btn-accent text-sm">Zum Kontakt</a>
          </div>

          <!-- Related areas link -->
          <div class="bg-white border border-bg-light p-6">
            <h2 class="font-heading font-semibold text-base text-text mb-3">
              Weitere Bereiche
            </h2>
            <a
              href="/de/expertise/"
              class="text-sm font-heading font-semibold text-accent hover:underline"
            >
              Alle Tätigkeitsbereiche →
            </a>
          </div>
        </aside>
      </div>
    </div>
  </div>
</BaseLayout>
