---
export const prerender = true;
import BaseLayout from '../../../components/layout/BaseLayout.astro';
import OpenStreetMap from '../../../components/ui/OpenStreetMap.astro';

const locale = 'de';
const canonicalUrl = 'https://www.core-attorneys.com/de/kontakt/';
const alternateUrl = 'https://www.core-attorneys.com/en/contact/';

const contactSchema = {
  '@context': 'https://schema.org',
  '@type': 'ContactPage',
  url: canonicalUrl,
  name: 'Kontakt – CORE Attorneys',
  inLanguage: 'de-CH',
  about: { '@id': 'https://www.core-attorneys.com/#organization' },
};
---
export const prerender = true;

<BaseLayout
  title="Kontakt | CORE Attorneys"
  description="CORE Attorneys – Dufourstrasse 105, CH-8008 Zürich. Telefon: +41 43 555 70 00. E-Mail: info@core-attorneys.com."
  locale={locale}
  canonicalUrl={canonicalUrl}
  alternateUrl={alternateUrl}
  schemas={[contactSchema]}
>
  <div class="py-12 bg-bg-light border-b border-bg-light">
    <div class="container">
      <nav aria-label="Brotkrümelpfad" class="mb-4">
        <ol class="flex items-center gap-2 text-sm font-sans text-text/50 list-none m-0 p-0">
          <li><a href="/de/" class="hover:text-accent transition-colors">Startseite</a></li>
          <li aria-hidden="true" class="text-text/30">/</li>
          <li class="text-text" aria-current="page">Kontakt</li>
        </ol>
      </nav>
      <h1 class="font-heading font-bold text-text" style="font-size: clamp(32px, 5vw, 48px);">
        Kontakt
      </h1>
      <p class="font-sans text-lg text-text/60 mt-3">
        Wir freuen uns auf Ihre Anfrage.
      </p>
    </div>
  </div>

  <section class="py-16 lg:py-20">
    <div class="container">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16">

        <!-- Contact details -->
        <div>
          <div class="w-12 h-1 bg-accent mb-8" aria-hidden="true"></div>

          <dl class="space-y-8">
            <!-- Address -->
            <div>
              <dt class="font-heading font-semibold text-sm uppercase tracking-wider text-text/50 mb-2">
                Adresse
              </dt>
              <dd>
                <address class="not-italic font-sans text-lg text-text leading-relaxed">
                  CORE Attorneys AG<br />
                  Dufourstrasse 105<br />
                  CH-8008 Zürich<br />
                  Schweiz
                </address>
              </dd>
            </div>

            <!-- Phone -->
            <div>
              <dt class="font-heading font-semibold text-sm uppercase tracking-wider text-text/50 mb-2">
                Telefon
              </dt>
              <dd>
                <a
                  href="tel:+41435557000"
                  class="font-sans text-lg text-text hover:text-accent transition-colors no-underline"
                >
                  +41 43 555 70 00
                </a>
              </dd>
            </div>

            <!-- Email -->
            <div>
              <dt class="font-heading font-semibold text-sm uppercase tracking-wider text-text/50 mb-2">
                E-Mail
              </dt>
              <dd>
                <a
                  href="mailto:info@core-attorneys.com"
                  class="font-sans text-lg text-accent hover:text-accent-dark transition-colors"
                >
                  info@core-attorneys.com
                </a>
              </dd>
            </div>

            <!-- Office hours -->
            <div>
              <dt class="font-heading font-semibold text-sm uppercase tracking-wider text-text/50 mb-2">
                Bürozeiten
              </dt>
              <dd class="font-sans text-lg text-text">
                Montag – Freitag<br />
                08:30 – 18:00 Uhr
              </dd>
            </div>

            <!-- LinkedIn -->
            <div>
              <dt class="font-heading font-semibold text-sm uppercase tracking-wider text-text/50 mb-2">
                LinkedIn
              </dt>
              <dd>
                <a
                  href="https://www.linkedin.com/company/core-attorneys"
                  target="_blank"
                  rel="noopener noreferrer"
                  class="font-sans text-lg text-accent hover:underline"
                  aria-label="CORE Attorneys auf LinkedIn (öffnet in neuem Tab)"
                >
                  CORE Attorneys auf LinkedIn
                </a>
              </dd>
            </div>
          </dl>
        </div>

        <!-- Map -->
        <div>
          <h2 class="font-heading font-semibold text-xl text-text mb-4 sr-only">
            Standort auf der Karte
          </h2>
          <OpenStreetMap locale={locale} lat={47.3645} lon={8.5532} zoom={16} />
        </div>

      </div>
    </div>
  </section>
</BaseLayout>
