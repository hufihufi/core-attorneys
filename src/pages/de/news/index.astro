---
export const prerender = true;
import { getCollection } from 'astro:content';
import BaseLayout from '../../../components/layout/BaseLayout.astro';
import NewsCard from '../../../components/cards/NewsCard.astro';

const locale = 'de';
const canonicalUrl = 'https://www.core-attorneys.com/de/news/';
const alternateUrl = 'https://www.core-attorneys.com/en/news/';

const allPosts = await getCollection('blog_de');
const publishedPosts = allPosts
  .filter((p) => !p.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---
export const prerender = true;

<BaseLayout
  title="News & Insights | CORE Attorneys"
  description="Aktuelle Beiträge zu Wettbewerbsrecht, Kartellrecht, Regulierung und Vertriebsrecht von CORE Attorneys Zürich."
  locale={locale}
  canonicalUrl={canonicalUrl}
  alternateUrl={alternateUrl}
>
  <div class="py-12 bg-bg-light border-b border-bg-light">
    <div class="container">
      <nav aria-label="Brotkrümelpfad" class="mb-4">
        <ol class="flex items-center gap-2 text-sm font-sans text-text/50 list-none m-0 p-0">
          <li><a href="/de/" class="hover:text-accent transition-colors">Startseite</a></li>
          <li aria-hidden="true" class="text-text/30">/</li>
          <li class="text-text" aria-current="page">News & Insights</li>
        </ol>
      </nav>
      <h1 class="font-heading font-bold text-text" style="font-size: clamp(32px, 5vw, 48px);">
        News & Insights
      </h1>
      <p class="font-sans text-lg text-text/60 mt-3 max-w-2xl">
        Aktuelle Entwicklungen und Einblicke aus dem Wettbewerbs- und Regulierungsrecht.
      </p>
    </div>
  </div>

  <section class="py-16 lg:py-20" aria-label="Alle Artikel">
    <div class="container">
      {publishedPosts.length > 0 ? (
        <ul
          class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 list-none m-0 p-0"
          role="list"
        >
          {publishedPosts.map((post) => (
            <li class="flex">
              <NewsCard
                locale={locale}
                title={post.data.title}
                description={post.data.description}
                pubDate={post.data.pubDate}
                slug={post.slug.split('/').pop() ?? post.slug}
                tags={post.data.tags}
                heroImage={post.data.heroImage}
              />
            </li>
          ))}
        </ul>
      ) : (
        <p class="font-sans text-text/60">Keine Artikel vorhanden.</p>
      )}
    </div>
  </section>
</BaseLayout>
