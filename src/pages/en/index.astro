---
import BaseLayout from '../../components/layout/BaseLayout.astro';
import Hero from '../../components/sections/Hero.astro';
import ExpertiseGrid from '../../components/sections/ExpertiseGrid.astro';
import AboutSection from '../../components/sections/AboutSection.astro';
import TeamPreview from '../../components/sections/TeamPreview.astro';
import NewsPreview from '../../components/sections/NewsPreview.astro';
import LinkedInFeed from '../../components/sections/LinkedInFeed.astro';

const locale = 'en';
const canonicalUrl = 'https://www.core-attorneys.com/en/';
const alternateUrl = 'https://www.core-attorneys.com/de/';

const homepageSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  '@id': canonicalUrl,
  url: canonicalUrl,
  name: 'CORE Attorneys – Competition Law, Regulatory, Distribution Law',
  description:
    'CORE Attorneys is an independent Swiss boutique law firm specialising in competition law, regulatory matters and distribution law in Zurich.',
  inLanguage: 'en',
  isPartOf: { '@id': 'https://www.core-attorneys.com/#organization' },
};
---

<BaseLayout
  title="CORE Attorneys – Competition Law & Regulatory, Zurich"
  description="CORE Attorneys is an independent Swiss boutique law firm specialising in competition law, regulatory matters and distribution law in Zurich."
  locale={locale}
  canonicalUrl={canonicalUrl}
  alternateUrl={alternateUrl}
  schemas={[homepageSchema]}
>
  <Hero locale={locale} />
  <ExpertiseGrid locale={locale} featured={true} />
  <AboutSection locale={locale} />
  <TeamPreview locale={locale} limit={4} />
  <NewsPreview locale={locale} limit={3} />
  <LinkedInFeed locale={locale} />
</BaseLayout>
