---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../components/layout/BaseLayout.astro';
import { formatDate } from '../../../utils/i18n';

export async function getStaticPaths() {
  const posts = await getCollection('blog_en');
  return posts
    .filter((p) => !p.data.draft)
    .map((post) => ({
      params: { slug: post.slug.split('/').pop() ?? post.slug },
      props: { post },
    }));
}

const { post } = Astro.props;
const { Content } = await post.render();

const locale = 'en';
const slug = post.slug.split('/').pop() ?? post.slug;
const canonicalUrl = `https://www.core-attorneys.com/en/news/${slug}/`;
const alternateUrl = `https://www.core-attorneys.com/de/news/${slug}/`;

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: post.data.title,
  description: post.data.description,
  datePublished: post.data.pubDate.toISOString(),
  dateModified: (post.data.updatedDate ?? post.data.pubDate).toISOString(),
  author: {
    '@type': 'Organization',
    name: post.data.author,
    url: 'https://www.core-attorneys.com',
  },
  publisher: { '@id': 'https://www.core-attorneys.com/#organization' },
  url: canonicalUrl,
  inLanguage: 'en',
  ...(post.data.heroImage && { image: `https://www.core-attorneys.com${post.data.heroImage}` }),
};

const formattedDate = formatDate(post.data.pubDate, locale);
---

<BaseLayout
  title={post.data.title}
  description={post.data.description}
  locale={locale}
  canonicalUrl={canonicalUrl}
  alternateUrl={alternateUrl}
  ogType="article"
  ogImage={post.data.heroImage}
  publishedTime={post.data.pubDate.toISOString()}
  modifiedTime={(post.data.updatedDate ?? post.data.pubDate).toISOString()}
  schemas={[articleSchema]}
>
  <div class="py-12 bg-bg-light border-b border-bg-light">
    <div class="container max-w-4xl">
      <nav aria-label="Breadcrumb" class="mb-4">
        <ol class="flex items-center gap-2 text-sm font-sans text-text/50 list-none m-0 p-0">
          <li><a href="/en/" class="hover:text-accent transition-colors">Home</a></li>
          <li aria-hidden="true" class="text-text/30">/</li>
          <li><a href="/en/news/" class="hover:text-accent transition-colors">News & Insights</a></li>
          <li aria-hidden="true" class="text-text/30">/</li>
          <li class="text-text truncate max-w-xs" aria-current="page">{post.data.title}</li>
        </ol>
      </nav>

      {post.data.tags.length > 0 && (
        <div class="flex flex-wrap gap-2 mb-4">
          {post.data.tags.map((tag) => (
            <span class="text-xs font-sans bg-accent/10 text-accent px-2 py-0.5 rounded-sm">
              {tag}
            </span>
          ))}
        </div>
      )}

      <h1 class="font-heading font-bold text-text mb-4" style="font-size: clamp(28px, 4vw, 42px);">
        {post.data.title}
      </h1>

      <div class="flex items-center gap-4 text-sm font-sans text-text/50">
        <time datetime={post.data.pubDate.toISOString()}>{formattedDate}</time>
        <span aria-hidden="true">·</span>
        <span>{post.data.author}</span>
      </div>
    </div>
  </div>

  {post.data.heroImage && (
    <div class="bg-bg-light">
      <div class="container max-w-4xl">
        <img
          src={post.data.heroImage}
          alt=""
          aria-hidden="true"
          class="w-full aspect-video object-cover"
          loading="lazy"
          width="800"
          height="450"
        />
      </div>
    </div>
  )}

  <article class="py-12 lg:py-16" aria-label={post.data.title}>
    <div class="container max-w-3xl">
      <div class="prose prose-lg max-w-none
        prose-headings:font-heading prose-headings:text-text
        prose-a:text-accent prose-a:no-underline hover:prose-a:underline
        prose-strong:text-text prose-blockquote:border-accent">
        <Content />
      </div>
      <div class="mt-12 pt-8 border-t border-bg-light">
        <a
          href="/en/news/"
          class="inline-flex items-center gap-2 text-sm font-heading font-semibold text-accent hover:underline"
        >
          <svg aria-hidden="true" class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
          </svg>
          Back to News & Insights
        </a>
      </div>
    </div>
  </article>
</BaseLayout>
